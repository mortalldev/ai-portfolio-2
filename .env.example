# ──────────────────────────────────────────────────────────────
#  Public site URL — used for SEO canonical, sitemap, OG tags.
#  In production set this to your real domain (no trailing slash).
# ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ──────────────────────────────────────────────────────────────
#  Telegram contact pipeline.
#  The contact form on the site sends submissions to your Telegram.
#
#  1. Create a bot via @BotFather  ->  copy the token below.
#  2. Get your chat id: message @userinfobot  (or @getmyid_bot).
#     For a group, add the bot to the group and use the group id.
# ──────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:AAExampleTokenReplaceMeWithYourRealOne
TELEGRAM_CHAT_ID=123456789
